<Window x:Class="BinaryLens.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BinaryLens — Binary Analysis Workbench"
        Width="1280" Height="820"
        MinWidth="900" MinHeight="600"
        Background="{StaticResource BackgroundBrush}"
        AllowDrop="True"
        Drop="Window_Drop"
        PreviewDragOver="Window_PreviewDragOver">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolVis"/>
    </Window.Resources>

    <DockPanel>

        <!-- ── Menu bar ─────────────────────────────────────────── -->
        <Menu DockPanel.Dock="Top" Background="{StaticResource SurfaceBrush}"
              BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <MenuItem Header="_File">
                <MenuItem Header="_Open Binary…"   Click="MenuOpen_Click"   InputGestureText="Ctrl+O"/>
                <Separator/>
                <MenuItem Header="_Export">
                    <MenuItem Header="Export _HTML Report…"   Click="MenuExportHtml_Click"
                              x:Name="MenuExportHtml" IsEnabled="False"/>
                    <MenuItem Header="Export _JSON…"          Click="MenuExportJson_Click"
                              x:Name="MenuExportJson" IsEnabled="False"/>
                    <MenuItem Header="Export _CSV Files…"     Click="MenuExportCsv_Click"
                              x:Name="MenuExportCsv"  IsEnabled="False"/>
                    <Separator/>
                    <MenuItem Header="Save _Source / Disasm…" Click="MenuSaveSource_Click"
                              x:Name="MenuSaveSource"  IsEnabled="False"/>
                </MenuItem>
                <Separator/>
                <MenuItem Header="_Compare Two Binaries…"     Click="MenuCompare_Click"
                          x:Name="MenuCompare"/>
                <Separator/>
                <MenuItem Header="E_xit"           Click="MenuExit_Click"/>
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem Header="Clear Results"   Click="MenuClear_Click"/>
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="About BinaryLens" Click="MenuAbout_Click"/>
            </MenuItem>
        </Menu>

        <!-- ── Status bar ───────────────────────────────────────── -->
        <StatusBar DockPanel.Dock="Bottom" Height="26"
                   Background="{StaticResource SurfaceBrush}"
                   BorderBrush="{StaticResource BorderBrush}"
                   BorderThickness="0,1,0,0">
            <StatusBarItem>
                <TextBlock x:Name="StatusText" Text="Drop a binary here or use File → Open"
                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <ProgressBar x:Name="ProgressBar" Width="160" Height="12"
                             Minimum="0" Maximum="100" Visibility="Hidden"
                             Foreground="{StaticResource AccentBrush}"/>
            </StatusBarItem>
        </StatusBar>

        <!-- ── Main content: left panel + splitter + tab panels ─── -->
        <Grid x:Name="MainGrid" Margin="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="ColLeft" Width="280" MinWidth="200"/>
                <ColumnDefinition x:Name="ColSplitter" Width="4"/>
                <ColumnDefinition Width="*"   MinWidth="400"/>
            </Grid.ColumnDefinitions>

            <!-- ── Left panel ──────────────────────────────────── -->
            <Border x:Name="LeftPanel" Grid.Column="0"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,1,0">
                <DockPanel Margin="0">

                    <!-- Drop zone -->
                    <Border DockPanel.Dock="Top"
                            x:Name="DropZone"
                            Margin="12,12,12,8"
                            Height="72"
                            BorderBrush="{StaticResource AccentBrush}"
                            BorderThickness="2"
                            CornerRadius="6"
                            Background="#F0F7FF"
                            Cursor="Hand"
                            MouseLeftButtonDown="DropZone_Click">
                        <StackPanel HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                            <TextBlock Text="⬇" FontSize="24" HorizontalAlignment="Center"
                                       Foreground="{StaticResource AccentBrush}"/>
                            <TextBlock Text="Drop binary / Browse"
                                       FontSize="12" HorizontalAlignment="Center"
                                       Foreground="{StaticResource AccentBrush}"
                                       FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>

                    <!-- File summary block -->
                    <Border DockPanel.Dock="Top"
                            x:Name="FileSummaryPanel"
                            Margin="12,0,12,8"
                            Padding="10"
                            Background="{StaticResource BackgroundBrush}"
                            CornerRadius="6"
                            Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock x:Name="SumFileName"
                                       FontWeight="Bold" FontSize="12"
                                       TextWrapping="Wrap"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock x:Name="SumFileSize"
                                       FontSize="11"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="0,2,0,0"/>
                            <TextBlock x:Name="SumFileType"
                                       FontSize="11"
                                       Foreground="{StaticResource AccentBrush}"
                                       FontWeight="SemiBold"
                                       Margin="0,2,0,0"
                                       TextWrapping="Wrap"/>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <Border x:Name="BadgeDotNet" Style="{StaticResource CountBadge}"
                                        Visibility="Collapsed">
                                    <TextBlock Text=".NET" FontSize="10" Foreground="White"
                                               FontWeight="SemiBold"/>
                                </Border>
                                <Border x:Name="BadgeArx" Style="{StaticResource CountBadge}"
                                        Background="#CA5010"
                                        Visibility="Collapsed">
                                    <TextBlock Text="ARX" FontSize="10" Foreground="White"
                                               FontWeight="SemiBold"/>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Analysis tree -->
                    <TextBlock DockPanel.Dock="Top" Style="{StaticResource SectionHeader}"
                               Margin="16,4,0,4" Text="ANALYSIS TREE"/>
                    <TreeView x:Name="AnalysisTree"
                              Background="Transparent"
                              BorderThickness="0"
                              Margin="8,0,8,8"
                              SelectedItemChanged="AnalysisTree_SelectedItemChanged">
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="TreeViewItem">
                                <Setter Property="IsExpanded" Value="True"/>
                                <Setter Property="Padding"    Value="4,3"/>
                                <Setter Property="FontSize"   Value="12"/>
                            </Style>
                        </TreeView.ItemContainerStyle>
                    </TreeView>

                </DockPanel>
            </Border>

            <!-- ── Grid splitter ────────────────────────────────── -->
            <GridSplitter x:Name="MainSplitter" Grid.Column="1"
                          Width="4"
                          HorizontalAlignment="Stretch"
                          Background="{StaticResource BorderBrush}"
                          Cursor="SizeWE"/>

            <!-- ── Right panel: analysis content (tab strip hidden, tree navigates) ── -->
            <TabControl Grid.Column="2"
                        x:Name="AnalysisTabs"
                        Padding="0"
                        Margin="0"
                        Background="{StaticResource SurfaceBrush}">
                <TabControl.Template>
                    <ControlTemplate TargetType="TabControl">
                        <Grid KeyboardNavigation.TabNavigation="Local">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="0"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <!-- Tab strip row has height 0 — hidden but functional -->
                            <TabPanel Grid.Row="0" IsItemsHost="True"
                                      Background="Transparent"/>
                            <ContentPresenter Grid.Row="1"
                                              ContentSource="SelectedContent"/>
                        </Grid>
                    </ControlTemplate>
                </TabControl.Template>

                <!-- ─ PE Structure ────────────────────────────── -->
                <TabItem x:Name="TabPeStructure" Header="PE Structure">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Auto"
                                  Padding="16">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionHeader}" Text="PE HEADER"/>
                            <DataGrid x:Name="GridPeHeader"
                                      Margin="0,0,0,20"
                                      AutoGenerateColumns="False"
                                      ColumnWidth="Auto">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Property" Binding="{Binding Key}"   Width="180"/>
                                    <DataGridTextColumn Header="Value"    Binding="{Binding Value}" Width="Auto"/>
                                </DataGrid.Columns>
                            </DataGrid>

                            <TextBlock Style="{StaticResource SectionHeader}" Text="SECTIONS"/>
                            <DataGrid x:Name="GridSections"
                                      AutoGenerateColumns="False"
                                      ColumnWidth="Auto"
                                      HorizontalScrollBarVisibility="Auto">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Name"            Binding="{Binding Name}"            Width="80"/>
                                    <DataGridTextColumn Header="Virt. Address"   Binding="{Binding VirtualAddress}"  Width="Auto"/>
                                    <DataGridTextColumn Header="Virt. Size"      Binding="{Binding VirtualSize}"     Width="Auto"/>
                                    <DataGridTextColumn Header="Raw Size"        Binding="{Binding RawSize}"         Width="Auto"/>
                                    <DataGridTextColumn Header="Entropy"         Binding="{Binding EntropyDisplay}"  Width="Auto"/>
                                    <DataGridTextColumn Header="Note"            Binding="{Binding EntropyNote}"     Width="Auto"/>
                                    <DataGridTextColumn Header="Characteristics" Binding="{Binding Characteristics}" Width="Auto"/>
                                </DataGrid.Columns>
                            </DataGrid>

                            <!-- Entropy visualization -->
                            <TextBlock Style="{StaticResource SectionHeader}"
                                       Text="SECTION ENTROPY" Margin="0,20,0,8"/>
                            <Border BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1" CornerRadius="4"
                                    Padding="12" Background="White">
                                <StackPanel>
                                    <!-- Legend -->
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <Border Width="14" Height="14" Background="#4CAF50" CornerRadius="2" Margin="0,0,4,0"/>
                                        <TextBlock Text="Normal (0–6)" FontSize="10" Margin="0,0,12,0"
                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                        <Border Width="14" Height="14" Background="#FF9800" CornerRadius="2" Margin="0,0,4,0"/>
                                        <TextBlock Text="Moderate (6–7.5)" FontSize="10" Margin="0,0,12,0"
                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                        <Border Width="14" Height="14" Background="#F44336" CornerRadius="2" Margin="0,0,4,0"/>
                                        <TextBlock Text="High (7.5–8) packed/encrypted?" FontSize="10"
                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </StackPanel>
                                    <!-- Bar chart container (populated in code-behind) -->
                                    <ItemsControl x:Name="EntropyChart"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- ─ Imports ─────────────────────────────────── -->
                <TabItem x:Name="TabImports" Header="Imports">
                    <DockPanel Margin="16">
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal"
                                    Margin="0,0,0,8">
                            <TextBlock x:Name="LabelImports"
                                       Style="{StaticResource SectionHeader}"
                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBox x:Name="FilterImports"
                                     Width="200" Height="26"
                                     VerticalContentAlignment="Center"
                                     Padding="6,0"
                                     FontSize="12"
                                     TextChanged="FilterImports_Changed"
                                     Tag="Filter imports..."/>
                        </StackPanel>
                        <DataGrid x:Name="GridImports" AutoGenerateColumns="False">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="DLL"      Binding="{Binding DllName}"     Width="220"/>
                                <DataGridTextColumn Header="Function" Binding="{Binding DisplayName}" Width="*"/>
                                <DataGridTextColumn Header="Hint"     Binding="{Binding Hint}"        Width="80"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </TabItem>

                <!-- ─ Exports ─────────────────────────────────── -->
                <TabItem x:Name="TabExports" Header="Exports">
                    <DockPanel Margin="16">
                        <TextBlock DockPanel.Dock="Top"
                                   x:Name="LabelExports"
                                   Style="{StaticResource SectionHeader}"
                                   Margin="0,0,0,8"/>
                        <DataGrid x:Name="GridExports" AutoGenerateColumns="False">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Name"      Binding="{Binding DisplayName}" Width="*"/>
                                <DataGridTextColumn Header="RVA"       Binding="{Binding RvaAddress}"  Width="110"/>
                                <DataGridTextColumn Header="Ordinal"   Binding="{Binding Ordinal}"     Width="80"/>
                                <DataGridTextColumn Header="Forwarded" Binding="{Binding ForwardTarget}" Width="180"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </TabItem>

                <!-- ─ Strings ─────────────────────────────────── -->
                <TabItem x:Name="TabStrings" Header="Strings">
                    <DockPanel Margin="16">
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal"
                                    Margin="0,0,0,8">
                            <TextBlock x:Name="LabelStrings"
                                       Style="{StaticResource SectionHeader}"
                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBox x:Name="FilterStrings"
                                     Width="220" Height="26"
                                     VerticalContentAlignment="Center"
                                     Padding="6,0"
                                     FontSize="12"
                                     TextChanged="FilterStrings_Changed"
                                     Tag="Search strings..." Margin="0,0,8,0"/>
                            <ComboBox x:Name="FilterEncoding" Width="90" Height="26"
                                      FontSize="12" SelectionChanged="FilterEncoding_Changed">
                                <ComboBoxItem Content="All"     IsSelected="True"/>
                                <ComboBoxItem Content="ASCII"/>
                                <ComboBoxItem Content="UTF-16"/>
                            </ComboBox>
                        </StackPanel>
                        <DataGrid x:Name="GridStrings" AutoGenerateColumns="False">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Offset"   Binding="{Binding OffsetHex}" Width="100"/>
                                <DataGridTextColumn Header="Encoding" Binding="{Binding Encoding}"  Width="80"/>
                                <DataGridTextColumn Header="Value"    Binding="{Binding Value}"     Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </TabItem>

                <!-- ─ Resources ───────────────────────────────── -->
                <TabItem x:Name="TabResources" Header="Resources">
                    <DockPanel Margin="16">
                        <TextBlock DockPanel.Dock="Top"
                                   x:Name="LabelResources"
                                   Style="{StaticResource SectionHeader}"
                                   Margin="0,0,0,8"/>
                        <DataGrid x:Name="GridResources" AutoGenerateColumns="False">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Type"     Binding="{Binding Type}"        Width="160"/>
                                <DataGridTextColumn Header="Name"     Binding="{Binding Name}"        Width="120"/>
                                <DataGridTextColumn Header="Language" Binding="{Binding Language}"    Width="90"/>
                                <DataGridTextColumn Header="Size"     Binding="{Binding SizeDisplay}" Width="100"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </TabItem>

                <!-- ─ Dependencies ────────────────────────────── -->
                <TabItem x:Name="TabDeps" Header="Dependencies">
                    <DockPanel Margin="16">
                        <TextBlock DockPanel.Dock="Top" Style="{StaticResource SectionHeader}"
                                   Margin="0,0,0,4" Text="DEPENDENCY TREE"/>
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal"
                                    Margin="0,0,0,10">
                            <TextBlock FontSize="12"><Run Background="#F0FFF0">⬜</Run>
                                <Run Foreground="#555"> Found</Run></TextBlock>
                            <TextBlock FontSize="12"><Run Background="#FFF0F0">⬜</Run>
                                <Run Foreground="#555"> Not found</Run></TextBlock>
                            <TextBlock FontSize="12">
                                <Run Foreground="#CA5010" FontWeight="Bold">🔵</Run>
                                <Run Foreground="#555"> AutoCAD</Run></TextBlock>
                            <TextBlock FontSize="12"><Run>⚪</Run>
                                <Run Foreground="#555"> System DLL</Run></TextBlock>
                        </StackPanel>
                        <TreeView x:Name="DepTree"
                                  BorderThickness="1"
                                  BorderBrush="{StaticResource BorderBrush}">
                            <TreeView.ItemTemplate>
                                <HierarchicalDataTemplate
                                    ItemsSource="{Binding Children}">
                                    <TextBlock Text="{Binding DisplayText}"
                                               FontFamily="Consolas" FontSize="12"
                                               Margin="2,1"/>
                                </HierarchicalDataTemplate>
                            </TreeView.ItemTemplate>
                        </TreeView>
                    </DockPanel>
                </TabItem>

                <!-- ─ Source / Disassembly ────────────────────── -->
                <TabItem x:Name="TabSource" Header="Source / Disasm">
                    <DockPanel Margin="16">
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal"
                                    Margin="0,0,0,8">
                            <TextBlock x:Name="LabelSource"
                                       Style="{StaticResource SectionHeader}"
                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <Button Content="Save to file…" Style="{StaticResource SecondaryButton}"
                                    Click="SaveSource_Click" x:Name="BtnSaveSource"
                                    IsEnabled="False" Height="26" Padding="10,4" Margin="0,0,8,0"/>
                            <Button Content="Save LISP…" Style="{StaticResource SecondaryButton}"
                                    Click="SaveLisp_Click" x:Name="BtnSaveLisp"
                                    IsEnabled="False" Height="26" Padding="10,4" Margin="0,0,8,0"
                                    Visibility="Collapsed"/>
                            <Button Content="Copy all"      Style="{StaticResource SecondaryButton}"
                                    Click="CopySource_Click" x:Name="BtnCopySource"
                                    IsEnabled="False" Height="26" Padding="10,4"/>
                        </StackPanel>

                        <!-- .NET decompiled source / single-pane FAS bytecode -->
                        <RichTextBox x:Name="SourceBox"
                                     FontFamily="Consolas" FontSize="12"
                                     IsReadOnly="True"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto"
                                     BorderThickness="1"
                                     BorderBrush="{StaticResource BorderBrush}"
                                     Padding="8"
                                     Background="#FEFFFE"
                                     Visibility="Collapsed"/>

                        <!-- FAS single-module side-by-side: LISP (left) + Bytecode (right) -->
                        <Grid x:Name="SourceSplitGrid" Visibility="Collapsed">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="5"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <DockPanel Grid.Column="0">
                                <TextBlock DockPanel.Dock="Top" Text="RECONSTRUCTED LISP"
                                           FontWeight="SemiBold" FontSize="11"
                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                <RichTextBox x:Name="SplitLispBox" FontFamily="Consolas" FontSize="11"
                                             IsReadOnly="True" VerticalScrollBarVisibility="Auto"
                                             HorizontalScrollBarVisibility="Auto" BorderThickness="1"
                                             BorderBrush="{StaticResource BorderBrush}" Padding="6" Background="#F7FBF7"/>
                            </DockPanel>
                            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"
                                          Background="{StaticResource BorderBrush}"/>
                            <DockPanel Grid.Column="2">
                                <TextBlock DockPanel.Dock="Top" Text="BYTECODE DISASSEMBLY"
                                           FontWeight="SemiBold" FontSize="11"
                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                <RichTextBox x:Name="SplitDisasmBox" FontFamily="Consolas" FontSize="11"
                                             IsReadOnly="True" VerticalScrollBarVisibility="Auto"
                                             HorizontalScrollBarVisibility="Auto" BorderThickness="1"
                                             BorderBrush="{StaticResource BorderBrush}" Padding="6" Background="#FAFAFA"/>
                            </DockPanel>
                        </Grid>

                        <!-- FAS multi-module: sub-tabs, one per module -->
                        <TabControl x:Name="ModuleTabControl" Visibility="Collapsed"/>

                        <!-- Native disassembly -->
                        <DataGrid x:Name="GridDisasm"
                                  AutoGenerateColumns="False"
                                  Visibility="Collapsed">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Address"  Binding="{Binding Address}"  Width="110"/>
                                <DataGridTextColumn Header="Bytes"    Binding="{Binding Bytes}"    Width="170"/>
                                <DataGridTextColumn Header="Mnemonic" Binding="{Binding Mnemonic}" Width="100"/>
                                <DataGridTextColumn Header="Operands" Binding="{Binding Operands}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <TextBlock x:Name="NoSourceMsg"
                                   Text="No source or disassembly available."
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="13"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </DockPanel>
                </TabItem>

                <!-- ─ ARX ─────────────────────────────────────── -->
                <!-- ─ VB5/6 ──────────────────────────────────── -->
                <TabItem x:Name="TabVb" Header="VB5/6">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                        <StackPanel x:Name="VbPanel">
                            <TextBlock Style="{StaticResource SectionHeader}" Text="VISUAL BASIC 5/6 ANALYSIS"/>

                            <TextBlock x:Name="NoVbMsg"
                                       Text="No Visual Basic 5/6 characteristics detected."
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="13" Margin="0,8,0,0"/>

                            <StackPanel x:Name="VbDetails" Visibility="Collapsed">
                                <!-- Summary properties -->
                                <DataGrid x:Name="GridVbSummary"
                                          AutoGenerateColumns="False"
                                          Margin="0,0,0,16" MaxHeight="260">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Property" Binding="{Binding Key}"   Width="200"/>
                                        <DataGridTextColumn Header="Value"    Binding="{Binding Value}" Width="*"/>
                                    </DataGrid.Columns>
                                </DataGrid>

                                <!-- VB Objects — master grid (click to select) -->
                                <TextBlock Style="{StaticResource SectionHeader}"
                                           Text="OBJECTS (FORMS, MODULES, CLASSES)" Margin="0,8,0,6"/>
                                <DataGrid x:Name="GridVbObjects"
                                          AutoGenerateColumns="False"
                                          SelectionChanged="GridVbObjects_SelectionChanged"
                                          MaxHeight="200" Margin="0,0,0,4">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="#"         Binding="{Binding Index}"          Width="40"/>
                                        <DataGridTextColumn Header="Type"      Binding="{Binding ObjectType}"     Width="80"/>
                                        <DataGridTextColumn Header="Name"      Binding="{Binding Name}"           Width="*"/>
                                        <DataGridTextColumn Header="Controls"  Binding="{Binding Controls.Count}" Width="70"/>
                                        <DataGridTextColumn Header="Methods"   Binding="{Binding Methods.Count}"  Width="70"/>
                                    </DataGrid.Columns>
                                </DataGrid>

                                <!-- Object detail panel (shows when an object is selected) -->
                                <Border x:Name="VbObjectDetail" Visibility="Collapsed"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="1" CornerRadius="4"
                                        Margin="0,4,0,16" Padding="12">
                                    <StackPanel>
                                        <DockPanel Margin="0,0,0,8">
                                            <TextBlock x:Name="VbObjDetailHeader"
                                                       Style="{StaticResource SectionHeader}"
                                                       Text="OBJECT DETAIL" DockPanel.Dock="Left"/>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                <Button Content="📋 Copy"   Click="VbObjCopy_Click"   Padding="8,4" Margin="0,0,6,0"/>
                                                <Button Content="💾 Export" Click="VbObjExportFrm_Click" Padding="8,4"/>
                                            </StackPanel>
                                        </DockPanel>

                                        <!-- Two-column layout: Controls | Methods -->
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="12"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Controls list -->
                                            <StackPanel Grid.Column="0">
                                                <TextBlock x:Name="VbCtrlHeader" Text="Controls (0)"
                                                           FontWeight="SemiBold" FontSize="12"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           Margin="0,0,0,4"/>
                                                <ListBox x:Name="ListVbControls"
                                                         MaxHeight="200"
                                                         FontFamily="Consolas" FontSize="12"
                                                         Background="{StaticResource SurfaceBrush}"
                                                         Foreground="{StaticResource TextPrimaryBrush}"
                                                         BorderThickness="1"
                                                         BorderBrush="{StaticResource BorderBrush}"/>
                                            </StackPanel>

                                            <!-- Methods list -->
                                            <StackPanel Grid.Column="2">
                                                <TextBlock x:Name="VbMethodHeader" Text="Methods (0)"
                                                           FontWeight="SemiBold" FontSize="12"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           Margin="0,0,0,4"/>
                                                <ListBox x:Name="ListVbMethods"
                                                         MaxHeight="200"
                                                         FontFamily="Consolas" FontSize="12"
                                                         Background="{StaticResource SurfaceBrush}"
                                                         Foreground="{StaticResource TextPrimaryBrush}"
                                                         BorderThickness="1"
                                                         BorderBrush="{StaticResource BorderBrush}"/>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- COM / ActiveX imports -->
                                <TextBlock Style="{StaticResource SectionHeader}"
                                           x:Name="VbComHeader"
                                           Text="COM / ACTIVEX CONTROLS" Margin="0,0,0,6"/>
                                <DataGrid x:Name="GridVbCom"
                                          AutoGenerateColumns="False"
                                          MaxHeight="200" Margin="0,0,0,16">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Control" Binding="{Binding}" Width="*"/>
                                    </DataGrid.Columns>
                                </DataGrid>

                                <!-- API Declares -->
                                <TextBlock Style="{StaticResource SectionHeader}"
                                           x:Name="VbApiHeader"
                                           Text="DETECTED API REFERENCES" Margin="0,0,0,6"/>
                                <DataGrid x:Name="GridVbApi"
                                          AutoGenerateColumns="False"
                                          MaxHeight="200" Margin="0,0,0,16">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="DLL / API" Binding="{Binding}" Width="*"/>
                                    </DataGrid.Columns>
                                </DataGrid>

                                <!-- References -->
                                <TextBlock Style="{StaticResource SectionHeader}"
                                           x:Name="VbRefsHeader"
                                           Text="TYPE LIBRARY REFERENCES" Margin="0,0,0,6"/>
                                <DataGrid x:Name="GridVbRefs"
                                          AutoGenerateColumns="False"
                                          MaxHeight="160">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Reference" Binding="{Binding}" Width="*"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- ─ AutoCAD ARX ────────────────────────────────── -->
                <TabItem x:Name="TabArx" Header="ARX">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                        <StackPanel x:Name="ArxPanel">
                            <TextBlock Style="{StaticResource SectionHeader}" Text="AUTOCAD ARX ANALYSIS"/>

                            <!-- No ARX detected message -->
                            <TextBlock x:Name="NoArxMsg"
                                       Text="No AutoCAD ARX characteristics detected in this binary."
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="13"
                                       Margin="0,8,0,0"/>

                            <!-- ARX details (shown when IsArx = true) -->
                            <StackPanel x:Name="ArxDetails" Visibility="Collapsed">
                                <DataGrid x:Name="GridArxSummary"
                                          AutoGenerateColumns="False"
                                          Margin="0,0,0,16"
                                          MaxHeight="200">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Property" Binding="{Binding Key}"   Width="200"/>
                                        <DataGridTextColumn Header="Value"    Binding="{Binding Value}" Width="*"/>
                                    </DataGrid.Columns>
                                </DataGrid>

                                <TextBlock Style="{StaticResource SectionHeader}"
                                           Text="AUTOCAD IMPORTS" Margin="0,8,0,6"/>
                                <DataGrid x:Name="GridArxImports"
                                          AutoGenerateColumns="False"
                                          MaxHeight="160"
                                          Margin="0,0,0,16">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="DLL"  Binding="{Binding}" Width="*"/>
                                    </DataGrid.Columns>
                                </DataGrid>

                                <TextBlock Style="{StaticResource SectionHeader}"
                                           Text="OBJECTARX CLASS STRINGS" Margin="0,0,0,6"/>
                                <DataGrid x:Name="GridArxClasses"
                                          AutoGenerateColumns="False"
                                          MaxHeight="300">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Class / Namespace" Binding="{Binding}" Width="*"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- ─ Python (.pyc / .pyd) ────────────────────────── -->
                <TabItem x:Name="TabPython" Header="Python">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                        <StackPanel>

                            <TextBlock x:Name="NoPythonMsg"
                                       Text="No Python characteristics detected in this binary."
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="13" Margin="0,8,0,0"/>

                            <!-- .pyc info panel -->
                            <StackPanel x:Name="PycPanel" Visibility="Collapsed">
                                <TextBlock Style="{StaticResource SectionHeader}"
                                           Text="PYTHON BYTECODE (.pyc)"/>
                                <DataGrid x:Name="GridPycInfo"
                                          AutoGenerateColumns="False"
                                          Margin="0,0,0,16" MaxHeight="280">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Property" Binding="{Binding Key}"   Width="200"/>
                                        <DataGridTextColumn Header="Value"    Binding="{Binding Value}" Width="*"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                                <TextBlock Style="{StaticResource SectionHeader}"
                                           Text="DECOMPILED / DISASSEMBLED SOURCE" Margin="0,8,0,6"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <Button Content="Save source…" Style="{StaticResource SecondaryButton}"
                                            Click="SavePycSource_Click" Height="26" Padding="10,4"
                                            Margin="0,0,8,0"/>
                                    <Button Content="Copy" Style="{StaticResource SecondaryButton}"
                                            Click="CopyPycSource_Click" Height="26" Padding="10,4"/>
                                </StackPanel>
                                <RichTextBox x:Name="PycSourceBox"
                                             FontFamily="Consolas" FontSize="12"
                                             IsReadOnly="True" MinHeight="300"
                                             VerticalScrollBarVisibility="Auto"
                                             HorizontalScrollBarVisibility="Auto"
                                             BorderThickness="1"
                                             BorderBrush="{StaticResource BorderBrush}"
                                             Padding="8" Background="#FEFFFE"/>
                            </StackPanel>

                            <!-- .pyd info panel -->
                            <StackPanel x:Name="PydPanel" Visibility="Collapsed">
                                <TextBlock Style="{StaticResource SectionHeader}"
                                           Text="PYTHON EXTENSION MODULE (.pyd)"/>
                                <DataGrid x:Name="GridPydInfo"
                                          AutoGenerateColumns="False"
                                          Margin="0,0,0,16" MaxHeight="200">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Property" Binding="{Binding Key}"   Width="200"/>
                                        <DataGridTextColumn Header="Value"    Binding="{Binding Value}" Width="*"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                                <TextBlock Style="{StaticResource SectionHeader}"
                                           Text="PYTHON C API IMPORTS FOUND" Margin="0,8,0,6"/>
                                <DataGrid x:Name="GridPydApi"
                                          AutoGenerateColumns="False" MaxHeight="300">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Function" Binding="{Binding}" Width="*"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>

                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- ─ VLX / FAS ────────────────────────────────────── -->
                <TabItem x:Name="TabVlx" Header="VLX/FAS">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                        <StackPanel>
                            <TextBlock x:Name="NoVlxMsg"
                                       Text="No Visual LISP VLX/FAS file loaded."
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="13" Margin="0,8,0,0"/>

                            <StackPanel x:Name="VlxDetails" Visibility="Collapsed">

                                <TextBlock Style="{StaticResource SectionHeader}"
                                           Text="FILE SUMMARY"/>
                                <DataGrid x:Name="GridVlxHeader"
                                          AutoGenerateColumns="False"
                                          Margin="0,0,0,16" MaxHeight="200" ColumnWidth="Auto">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Property" Binding="{Binding Key}"   Width="180"/>
                                        <DataGridTextColumn Header="Value"    Binding="{Binding Value}" Width="*"/>
                                    </DataGrid.Columns>
                                </DataGrid>

                                <TextBlock Style="{StaticResource SectionHeader}"
                                           Text="HEADER HEX DUMP" Margin="0,8,0,6"/>
                                <RichTextBox x:Name="VlxHexBox"
                                             FontFamily="Consolas" FontSize="11"
                                             IsReadOnly="True" MaxHeight="160"
                                             VerticalScrollBarVisibility="Auto"
                                             HorizontalScrollBarVisibility="Auto"
                                             BorderThickness="1"
                                             BorderBrush="{StaticResource BorderBrush}"
                                             Padding="6" Background="#FAFAFA"/>

                                <TextBlock x:Name="VlxModulesHeader"
                                           Style="{StaticResource SectionHeader}"
                                           Margin="0,16,0,6"/>
                                <DataGrid x:Name="GridVlxModules"
                                          AutoGenerateColumns="False"
                                          Margin="0,0,0,16" MaxHeight="160" ColumnWidth="Auto">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="#"      Binding="{Binding Index}"         Width="40"/>
                                        <DataGridTextColumn Header="Name"   Binding="{Binding Name}"          Width="*"/>
                                        <DataGridTextColumn Header="Offset" Binding="{Binding OffsetDisplay}" Width="90"/>
                                        <DataGridTextColumn Header="Size"   Binding="{Binding SizeDisplay}"   Width="100"/>
                                    </DataGrid.Columns>
                                </DataGrid>

                                <TextBlock x:Name="VlxCommandsHeader"
                                           Style="{StaticResource SectionHeader}"
                                           Margin="0,0,0,6"/>
                                <DataGrid x:Name="GridVlxCommands"
                                          AutoGenerateColumns="False"
                                          Margin="0,0,0,16" MaxHeight="200" ColumnWidth="Auto">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Command (C:NAME)" Binding="{Binding}" Width="*"/>
                                    </DataGrid.Columns>
                                </DataGrid>

                                <TextBlock x:Name="VlxFunctionsHeader"
                                           Style="{StaticResource SectionHeader}"
                                           Margin="0,0,0,6"/>
                                <DataGrid x:Name="GridVlxFunctions"
                                          AutoGenerateColumns="False"
                                          Margin="0,0,0,16" MaxHeight="220" ColumnWidth="Auto">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Function Name" Binding="{Binding}" Width="*"/>
                                    </DataGrid.Columns>
                                </DataGrid>

                                <TextBlock x:Name="VlxGlobalsHeader"
                                           Style="{StaticResource SectionHeader}"
                                           Margin="0,0,0,6"/>
                                <DataGrid x:Name="GridVlxGlobals"
                                          AutoGenerateColumns="False"
                                          Margin="0,0,0,16" MaxHeight="160" ColumnWidth="Auto">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Global Variable (*VAR*)" Binding="{Binding}" Width="*"/>
                                    </DataGrid.Columns>
                                </DataGrid>

                                <TextBlock x:Name="VlxStringsHeader"
                                           Style="{StaticResource SectionHeader}"
                                           Margin="0,0,0,6"/>
                                <DataGrid x:Name="GridVlxStrings"
                                          AutoGenerateColumns="False"
                                          MaxHeight="300" ColumnWidth="Auto">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Offset"  Binding="{Binding OffsetDisplay}" Width="90"/>
                                        <DataGridTextColumn Header="Method"  Binding="{Binding Method}"        Width="90"/>
                                        <DataGridTextColumn Header="Value"   Binding="{Binding Value}"         Width="*"/>
                                    </DataGrid.Columns>
                                </DataGrid>

                                <!-- Embedded DCL/TXT files -->
                                <TextBlock x:Name="VlxEmbeddedHeader"
                                           Style="{StaticResource SectionHeader}"
                                           Margin="0,16,0,6"
                                           Visibility="Collapsed"/>
                                <RichTextBox x:Name="VlxEmbeddedBox"
                                             FontFamily="Consolas" FontSize="11"
                                             IsReadOnly="True" MaxHeight="300"
                                             VerticalScrollBarVisibility="Auto"
                                             HorizontalScrollBarVisibility="Auto"
                                             BorderThickness="1"
                                             BorderBrush="{StaticResource BorderBrush}"
                                             Padding="6" Background="#FAFAFA"
                                             Visibility="Collapsed"/>

                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

            </TabControl>
        </Grid>
    </DockPanel>
</Window>
